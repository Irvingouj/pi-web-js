{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"declaration": false,
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["chrome"],
		"lib": ["ES2022", "DOM", "DOM.Iterable"]
	},
	"include": [
		"content-script.ts",
		"runner.ts",
		"tool-registry.ts",
		"schemas.ts",
		"index.ts",
		"generated.ts"
	],
	"exclude": ["dist"]
}
