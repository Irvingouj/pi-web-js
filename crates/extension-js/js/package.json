{
	"name": "extension-js",
	"type": "module",
	"exports": {
		".": "./src/main/index.ts",
		"./worker": "./src/worker/worker.ts",
		"./content-script": "./src/content-script/index.ts"
	},
	"scripts": {
		"pretest": "cd ../../.. && node scripts/build.js extension",
		"test": "vitest run",
		"build": "npx tsc --noEmit && npx vite build && npx vite build --config vite.worker.config.ts && npx vite build --config vite.content-script.config.ts"
	},
	"dependencies": {
		"zod": "^3.23.8",
		"@pi-oxide/dom-semantic-tree": "^0.2.0"
	},
	"devDependencies": {
		"@types/chrome": "^0.1.42",
		"jsdom": "^29.1.1",
		"vitest": "^1.6.0",
		"vite": "^5.0.0",
		"vite-plugin-dts": "^3.0.0"
	}
}
