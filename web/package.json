{
  "name": "js-notebook",
  "version": "0.1.0",
  "private": true,
  "license": "LicenseRef-PiccoloNotebook-Fair-BYOK-1.0",
  "type": "module",
  "scripts": {
    "copy-ext-assets": "node scripts/copy-ext-assets.js",
    "copy-e2e-assets": "node scripts/copy-e2e-assets.js",
    "dev": "npm run copy-ext-assets && vite",
    "build": "vite build",
    "preview": "vite preview",
    "wasm": "cd .. && node scripts/build.js",
    "prebuild": "npm run wasm",
    "package:extension": "node scripts/package-extension.js",
    "deploy": "npm run build && npx gh-pages -d dist",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:web": "playwright test --config playwright.config.ts",
    "test:e2e:extension": "npm run copy-ext-assets && npm run copy-e2e-assets && npm run build && playwright test --config playwright.extension.config.ts",
    "test:e2e:extension:apis": "EXT_CONTRACT_APIS=1 npm run test:e2e:extension",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.50.0",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^20.0.0",
    "gh-pages": "^6.3.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "codemirror": "^6.0.2",
    "marked": "^18.0.4",
    "preact": "^10.29.2"
  }
}
